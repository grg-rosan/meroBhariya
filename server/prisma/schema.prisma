generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum Role {
  MERCHANT
  RIDER
  DISPATCHER
  ADMIN
}

enum ShipmentStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentType {
  COD
  PREPAID
}

enum MerchantDocType {
  PAN_CERTIFICATE
  BUSINESS_REGISTRATION
  TAX_CLEARANCE
  OWNER_CITIZENSHIP
  OWNER_PHOTO
}

enum RiderDocType {
  CITIZENSHIP_FRONT
  CITIZENSHIP_BACK
  DRIVING_LICENSE_FRONT
  DRIVING_LICENSE_BACK
  VEHICLE_BLUEBOOK
  VEHICLE_INSURANCE
  RIDER_PHOTO
  VEHICLE_PHOTO
}

enum SubStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum TxType {
  TOPUP
  SHIPMENT_CHARGE // ← replaces generic DEDUCTION for fare payments
  OVERAGE_CHARGE // ← separate line item for overage
  REFUND
  ADJUSTMENT
}

enum RiderTxType {
  DELIVERY_EARNING
  BONUS
  ADJUSTMENT
  DEDUCTION
}

enum PayoutMethod {
  ESEWA
  KHALTI
  BANK
  CASH
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CODStatus {
  PENDING
  COLLECTED
  REMITTED
  RECONCILED
  FAILED
}

//_____________USERS_____________
model User {
  id              String   @id @default(cuid())
  fullName        String
  email           String   @unique
  passwordHash    String
  phoneNumber     String   @unique
  role            Role     @default(MERCHANT)
  isActive        Boolean  @default(true)
  isEmailVerified Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchantProfile   MerchantProfile?
  riderProfile      RiderProfile?
  logs              ShipmentLog[]
  // For handoff tracking — User who initiated a handoff
  initiatedHandoffs Shipment[]       @relation("HandoffInitiator")
  codRemittances    CODRecord[]      @relation("CODRemittedTo")
  codReconciled     CODRecord[]      @relation("CODReconciledBy")
}

// ─── MERCHANT MODELS ─────────────────────────────────────────

model MerchantProfile {
  id            String                                 @id @default(cuid())
  userId        String                                 @unique @map("user_id")
  user          User                                   @relation(fields: [userId], references: [id])
  businessName  String
  panNumber     String?
  pickupAddress String
  isVerified    Boolean                                @default(false)
  // PostGIS point — used by computeFare middleware for distance calc
  location      Unsupported("geography(Point, 4326)")?

  documents    MerchantDocument[]
  shipments    Shipment[]
  subscription MerchantSubscription?
  wallet       MerchantWallet?
}

model MerchantSubscription {
  id                 String          @id @default(cuid())
  merchantId         String          @unique
  merchant           MerchantProfile @relation(fields: [merchantId], references: [id])
  planId             String
  plan               Plan            @relation(fields: [planId], references: [id])
  status             SubStatus       @default(ACTIVE)
  shipmentsUsed      Int             @default(0)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime        @default(now())

  @@index([merchantId, status]) // checkSubscription middleware queries this
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  price         Decimal
  shipmentQuota Int? // null = unlimited
  overageRate   Decimal? // null = hard block at quota
  isActive      Boolean  @default(true)

  subscriptions MerchantSubscription[]
}

model MerchantWallet {
  id         String          @id @default(cuid())
  merchantId String          @unique
  merchant   MerchantProfile @relation(fields: [merchantId], references: [id])
  balance    Decimal         @default(0)

  transactions MerchantTransaction[]
}

model MerchantTransaction {
  id         String         @id @default(cuid())
  walletId   String
  wallet     MerchantWallet @relation(fields: [walletId], references: [id])
  // Proper FK — checkWalletBalance deducts against a specific shipment
  shipmentId String?
  shipment   Shipment?      @relation(fields: [shipmentId], references: [id])
  type       TxType
  amount     Decimal
  note       String?
  createdAt  DateTime       @default(now())

  @@index([walletId])
  @@index([shipmentId])
}

// ─── RIDER MODELS ────────────────────────────────────────────

model RiderProfile {
  id              String                                 @id @default(cuid())
  userId          String                                 @unique @map("user_id")
  user            User                                   @relation(fields: [userId], references: [id])
  vehicleTypeId   Int
  vehicleType     VehicleType                            @relation(fields: [vehicleTypeId], references: [id])
  licenseNumber   String                                 @unique
  vehicleNumber   String                                 @unique
  isOnline        Boolean                                @default(false)
  isVerified      Boolean                                @default(false)
  // Updated by rider app on each location ping
  currentLocation Unsupported("geography(Point, 4326)")?

  documents      RiderDocument[]
  shipments      Shipment[]
  wallet         RiderWallet? // auto-created on profile creation
  payouts        RiderPayout[]
  codCollections CODRecord[]     @relation("CODCollectedBy")

  @@index([vehicleTypeId])
  @@index([isOnline, isVerified]) // dispatcher queries available riders
}

model RiderWallet {
  id          String       @id @default(cuid())
  riderId     String       @unique
  rider       RiderProfile @relation(fields: [riderId], references: [id])
  balance     Decimal      @default(0)
  totalEarned Decimal      @default(0) // lifetime stat, never decremented

  transactions RiderTransaction[]
}

model RiderTransaction {
  id         String      @id @default(cuid())
  walletId   String
  wallet     RiderWallet @relation(fields: [walletId], references: [id])
  // One earning record per shipment delivery
  shipmentId String?     @unique
  shipment   Shipment?   @relation(fields: [shipmentId], references: [id])
  type       RiderTxType
  amount     Decimal
  note       String?
  createdAt  DateTime    @default(now())

  @@index([walletId])
  @@index([shipmentId])
}

model RiderPayout {
  id          String       @id @default(cuid())
  riderId     String
  rider       RiderProfile @relation(fields: [riderId], references: [id])
  amount      Decimal
  method      PayoutMethod
  status      PayoutStatus @default(PENDING)
  requestedAt DateTime     @default(now())
  processedAt DateTime?

  @@index([riderId, status])
}

// ─── VEHICLE & FARE ──────────────────────────────────────────

model VehicleType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  maxWeightKg Float
  description String?
  isActive    Boolean @default(true)

  riders     RiderProfile[]
  shipments  Shipment[]
  fareConfig FareConfig?
}

model FareConfig {
  id            Int         @id @default(autoincrement())
  vehicleTypeId Int         @unique
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id])
  baseFare      Float
  perKmRate     Float
  perKgRate     Float
  minFare       Float
  fragileCharge Decimal @default(0)
  // riderCutPct used by RiderTransaction creation after delivery
  riderCutPct   Decimal     @default(75.0)
  isActive      Boolean     @default(true)
  updatedAt     DateTime    @updatedAt
}

// ─── SHIPMENT ────────────────────────────────────────────────

model Shipment {
  id             String          @id @default(cuid())
  trackingNumber String          @unique
  merchantId     String
  merchant       MerchantProfile @relation(fields: [merchantId], references: [id])
  riderId        String?
  rider          RiderProfile?   @relation(fields: [riderId], references: [id])
  vehicleTypeId  Int
  vehicleType    VehicleType     @relation(fields: [vehicleTypeId], references: [id])

  receiverName     String
  receiverPhone    String
  deliveryAddress  String
  // PostGIS point derived from deliveryLat/Lng at creation
  deliveryLocation Unsupported("geography(Point, 4326)")?
  deliveryLat      Float?
  deliveryLng      Float? // ← typo fixed (was devliveryLng)

  weight       Float
  isFragile    Boolean @default(false)
  orderValue   Float
  codAmount    Float   @default(0)
  // Frozen at creation by computeFare middleware
  fareSnapshot Float?
  distanceKm   Float? // ← store computed distance for audit/reporting

  status      ShipmentStatus @default(PENDING)
  paymentType PaymentType    @default(PREPAID)

  // Handoff — proper FK to User instead of raw String
  isHandoffPending   Boolean @default(false)
  handoffInitiatorId String?
  handoffInitiator   User?   @relation("HandoffInitiator", fields: [handoffInitiatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs             ShipmentLog[]
  transaction      Transaction?
  codRecord        CODRecord?
  merchantCharges  MerchantTransaction[] // fare + overage deductions
  riderTransaction RiderTransaction? // ← one-to-one earning record

  @@index([merchantId])
  @@index([riderId])
  @@index([status])
  @@index([trackingNumber])
}

// ─── COD ─────────────────────────────────────────────────────

model CODRecord {
  id         String    @id @default(cuid())
  shipmentId String    @unique
  shipment   Shipment  @relation(fields: [shipmentId], references: [id])
  amount     Decimal
  status     CODStatus @default(PENDING)

  // Proper FKs instead of raw strings
  collectedById String?
  collectedBy   RiderProfile? @relation("CODCollectedBy", fields: [collectedById], references: [id])
  collectedAt   DateTime?

  remittedToId String?
  remittedTo   User?     @relation("CODRemittedTo", fields: [remittedToId], references: [id])
  remittedAt   DateTime?

  reconciledById String?
  reconciledBy   User?     @relation("CODReconciledBy", fields: [reconciledById], references: [id])
  reconciledAt   DateTime?

  merchantPayout Decimal?
  notes          String?
}

// ─── DOCUMENTS ───────────────────────────────────────────────

model MerchantDocument {
  id         String          @id @default(cuid())
  merchantId String
  merchant   MerchantProfile @relation(fields: [merchantId], references: [id])
  type       MerchantDocType
  fileUrl    String
  status     DocumentStatus  @default(PENDING)
  uploadedAt DateTime        @default(now())
  // Admin review trail
  reviewedAt DateTime?
  reviewNote String?

  @@index([merchantId, status])
}

model RiderDocument {
  id         String         @id @default(cuid())
  riderId    String
  rider      RiderProfile   @relation(fields: [riderId], references: [id])
  type       RiderDocType
  fileUrl    String
  status     DocumentStatus @default(PENDING)
  uploadedAt DateTime       @default(now())
  reviewedAt DateTime?
  reviewNote String?

  @@index([riderId, status])
}

// ─── LOGS & TRANSACTION ──────────────────────────────────────

model ShipmentLog {
  id          String         @id @default(cuid())
  shipmentId  String
  shipment    Shipment       @relation(fields: [shipmentId], references: [id])
  status      ShipmentStatus
  note        String?
  updatedById String
  updatedBy   User           @relation(fields: [updatedById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([shipmentId])
}

model Transaction {
  id               String      @id @default(cuid())
  shipmentId       String      @unique
  shipment         Shipment    @relation(fields: [shipmentId], references: [id])
  paymentType      PaymentType
  totalFare        Float
  codAmount        Float       @default(0)
  collectedByRider Float       @default(0)
  isRemitted       Boolean     @default(false)
  remittedAt       DateTime?
  createdAt        DateTime    @default(now())
}
