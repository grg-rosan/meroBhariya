generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

//_________enum_________
enum Role {
  MERCHANT
  RIDER
  DISPATCHER
  ADMIN
}

enum ShipmentStatus {
  UNPAID
  PENDING
  AWAITING_PICKUP
  ASSIGNED
  PICKED_UP
  IN_HUB
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentType {
  COD
  PREPAID
}

enum MerchantDocType {
  PAN_CERTIFICATE
  BUSINESS_REGISTRATION
  TAX_CLEARANCE
  OWNER_CITIZENSHIP
  OWNER_PHOTO
}

enum RiderDocType {
  CITIZENSHIP_FRONT
  CITIZENSHIP_BACK
  DRIVING_LICENSE_FRONT
  DRIVING_LICENSE_BACK
  VEHICLE_BLUEBOOK
  VEHICLE_INSURANCE
  RIDER_PHOTO
  VEHICLE_PHOTO
}

enum RiderTxType {
  DELIVERY_EARNING
  BONUS
  ADJUSTMENT
  DEDUCTION
}

enum PayoutMethod {
  ESEWA
  KHALTI
  BANK
  CASH
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CODStatus {
  PENDING
  COLLECTED
  REMITTED
  RECONCILED
  FAILED
}

enum KhaltiPaymentStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ClaimStatus {
  RAISED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
}

//_________users
model User {
  id              String   @id @default(cuid())
  fullName        String
  email           String   @unique
  passwordHash    String
  phoneNumber     String   @unique
  role            Role     @default(MERCHANT)
  isActive        Boolean  @default(true)
  isEmailVerified Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchantProfile   MerchantProfile?
  riderProfile      RiderProfile?
  logs              ShipmentLog[]
  initiatedHandoffs Shipment[]       @relation("HandoffInitiator")
  codRemittances    CODRecord[]      @relation("CODRemittedTo")
  codReconciled     CODRecord[]      @relation("CODReconciledBy")
}

//_________merchant_________
model MerchantProfile {
  id            String                                 @id @default(cuid())
  userId        String                                 @unique @map("user_id")
  user          User                                   @relation(fields: [userId], references: [id])
  businessName  String
  panNumber     String?
  pickupAddress String
  isVerified    Boolean                                @default(false)
  // PostGIS point — origin for distance calculation
  location      Unsupported("geography(Point, 4326)")?

  documents      MerchantDocument[]
  shipments      Shipment[]
  khaltiPayments KhaltiPayment[]
}

//_________zone & district
model Zone {
  id          Int     @id @default(autoincrement())
  name        String // "Valley", "Highway", "Outstation", "Remote"
  description String?
  // Flat surcharge added on top of distance+weight fare
  surcharge   Decimal @default(0)
  // Optional multiplier for very remote zones (e.g. 1.2 = 20% extra)
  multiplier  Decimal @default(1.0)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  districts District[]
  shipments Shipment[]
}

model District {
  id       Int    @id @default(autoincrement())
  name     String // "Kathmandu", "Parsa", "Pokhara"
  province String // "Bagmati", "Madhesh", "Gandaki"
  zoneId   Int
  zone     Zone   @relation(fields: [zoneId], references: [id])

  shipmentsFrom Shipment[] @relation("FromDistrict")
  shipmentsTo   Shipment[] @relation("ToDistrict")

  @@index([zoneId])
}

//_________vehicle_________
model VehicleType {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  maxWeightKg Float
  description String?
  isActive    Boolean @default(true)

  riders     RiderProfile[]
  shipments  Shipment[]
  fareConfig FareConfig?
}

model FareConfig {
  id            Int         @id @default(autoincrement())
  vehicleTypeId Int         @unique
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id])

  baseFare      Float // flat base charge
  perKmRate     Float // Rs. per km
  perKgRate     Float // Rs. per kg
  minFare       Float // minimum fare floor
  fragileCharge Decimal @default(0) // extra for fragile items

  // Insurance rate — applied to orderValue, internal only, never shown to merchant
  insuranceRate Decimal @default(1.0) // percentage e.g. 1.0 = 1%

  // Fuel surcharge — % on top of total, for future use
  fuelSurcharge Decimal @default(0)

  // Rider cut — used by RiderTransaction after delivery
  riderCutPct   Decimal  @default(75.0)
  codChargeRate Decimal  @default(1.5)
  isActive      Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

// ─── SHIPMENT ────────────────────────────────────────────────

model Shipment {
  id             String          @id @default(cuid())
  trackingNumber String          @unique
  merchantId     String
  merchant       MerchantProfile @relation(fields: [merchantId], references: [id])
  riderId        String?
  rider          RiderProfile?   @relation(fields: [riderId], references: [id])
  vehicleTypeId  Int
  vehicleType    VehicleType     @relation(fields: [vehicleTypeId], references: [id])

  // Receiver & Delivery
  receiverName     String
  receiverPhone    String
  deliveryAddress  String
  deliveryLocation Unsupported("geography(Point, 4326)")?
  deliveryLat      Float?
  deliveryLng      Float?

  // Districts — origin and destination
  fromDistrictId Int?
  fromDistrict   District? @relation("FromDistrict", fields: [fromDistrictId], references: [id])
  toDistrictId   Int?
  toDistrict     District? @relation("ToDistrict", fields: [toDistrictId], references: [id])

  // Zone — destination zone (harder zone wins if different)
  zoneId Int?
  zone   Zone? @relation(fields: [zoneId], references: [id])

  // Shipment Details
  weight     Float
  isFragile  Boolean @default(false)
  orderValue Float
  codAmount  Float   @default(0)

  // Fare — all frozen at creation by computeFare middleware
  distanceKm    Float? // computed via PostGIS
  baseFare      Decimal? // FareConfig.baseFare snapshot
  distanceFare  Decimal? // distanceKm × perKmRate
  weightFare    Decimal? // weight × perKgRate
  fragileCharge Decimal? // if isFragile
  zoneSurcharge Decimal? // Zone.surcharge snapshot
  insuranceFee  Decimal? // internal only — never exposed to merchant
  totalFare     Decimal? // what merchant sees = all above combined
  codFee        Decimal?

  // Legacy — keep for backward compat
  fareSnapshot Float?

  status      ShipmentStatus @default(PENDING)
  paymentType PaymentType    @default(PREPAID)

  // Khalti payment for this shipment
  khaltiPayment KhaltiPayment?

  // Handoff
  isHandoffPending   Boolean @default(false)
  handoffInitiatorId String?
  handoffInitiator   User?   @relation("HandoffInitiator", fields: [handoffInitiatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs             ShipmentLog[]
  transaction      Transaction?
  codRecord        CODRecord?
  riderTransaction RiderTransaction?
  insuranceClaim   InsuranceClaim?

  @@index([merchantId])
  @@index([riderId])
  @@index([status])
  @@index([trackingNumber])
  @@index([fromDistrictId])
  @@index([toDistrictId])
  @@index([zoneId])
}

//_________khalti payment _________
model KhaltiPayment {
  id         String          @id @default(cuid())
  merchantId String
  merchant   MerchantProfile @relation(fields: [merchantId], references: [id])

  // Per shipment payment
  shipmentId String?   @unique
  shipment   Shipment? @relation(fields: [shipmentId], references: [id])

  amount Decimal
  status KhaltiPaymentStatus @default(INITIATED)

  // Khalti response fields
  pidx      String? @unique // Khalti payment index
  txnId     String? // Khalti transaction id
  khaltiRef String? // Khalti reference number

  initiatedAt DateTime  @default(now())
  completedAt DateTime?
  failedAt    DateTime?
  failReason  String?

  @@index([merchantId])
  @@index([shipmentId])
  @@index([pidx])
}

// ─── INSURANCE CLAIM ─────────────────────────────────────────

// Internal — merchant raises claim for lost/damaged shipment
model InsuranceClaim {
  id         String   @id @default(cuid())
  shipmentId String   @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  merchantId String

  reason      String
  description String?
  // Cannot exceed shipment.orderValue
  claimAmount Decimal
  status      ClaimStatus @default(RAISED)

  // Admin review
  reviewNote String?
  reviewedAt DateTime?

  // Payout
  approvedAmount Decimal?
  paidAt         DateTime?

  createdAt DateTime @default(now())

  @@index([merchantId])
  @@index([status])
}

//_________rider_________
model RiderProfile {
  id              String                                 @id @default(cuid())
  userId          String                                 @unique @map("user_id")
  user            User                                   @relation(fields: [userId], references: [id])
  vehicleTypeId   Int
  vehicleType     VehicleType                            @relation(fields: [vehicleTypeId], references: [id])
  licenseNumber   String                                 @unique
  vehicleNumber   String                                 @unique
  isOnline        Boolean                                @default(false)
  isVerified      Boolean                                @default(false)
  currentLocation Unsupported("geography(Point, 4326)")?

  documents      RiderDocument[]
  shipments      Shipment[]
  wallet         RiderWallet?
  payouts        RiderPayout[]
  codCollections CODRecord[]     @relation("CODCollectedBy")

  @@index([vehicleTypeId])
  @@index([isOnline, isVerified])
}

model RiderWallet {
  id          String       @id @default(cuid())
  riderId     String       @unique
  rider       RiderProfile @relation(fields: [riderId], references: [id])
  balance     Decimal      @default(0)
  totalEarned Decimal      @default(0)

  transactions RiderTransaction[]
}

model RiderTransaction {
  id         String      @id @default(cuid())
  walletId   String
  wallet     RiderWallet @relation(fields: [walletId], references: [id])
  shipmentId String?     @unique
  shipment   Shipment?   @relation(fields: [shipmentId], references: [id])
  type       RiderTxType
  amount     Decimal
  note       String?
  createdAt  DateTime    @default(now())

  @@index([walletId])
  @@index([shipmentId])
}

model RiderPayout {
  id          String       @id @default(cuid())
  riderId     String
  rider       RiderProfile @relation(fields: [riderId], references: [id])
  amount      Decimal
  method      PayoutMethod
  status      PayoutStatus @default(PENDING)
  requestedAt DateTime     @default(now())
  processedAt DateTime?

  @@index([riderId, status])
}
//_________cod_________
model CODRecord {
  id         String    @id @default(cuid())
  shipmentId String    @unique
  shipment   Shipment  @relation(fields: [shipmentId], references: [id])
  amount     Decimal
  status     CODStatus @default(PENDING)

  collectedById String?
  collectedBy   RiderProfile? @relation("CODCollectedBy", fields: [collectedById], references: [id])
  collectedAt   DateTime?

  remittedToId String?
  remittedTo   User?     @relation("CODRemittedTo", fields: [remittedToId], references: [id])
  remittedAt   DateTime?

  reconciledById String?
  reconciledBy   User?     @relation("CODReconciledBy", fields: [reconciledById], references: [id])
  reconciledAt   DateTime?

  merchantPayout Decimal?
  notes          String?

  khaltiRef   String? // Khalti reference when admin remits to merchant
  khaltiTxnId String? // Khalti transaction ID
  paidAt      DateTime? // when admin actually paid merchant
}

//_________documents_________
model MerchantDocument {
  id         String          @id @default(cuid())
  merchantId String
  merchant   MerchantProfile @relation(fields: [merchantId], references: [id])
  type       MerchantDocType
  fileUrl    String
  status     DocumentStatus  @default(PENDING)
  uploadedAt DateTime        @default(now())
  reviewedAt DateTime?
  reviewNote String?

  @@index([merchantId, status])
}

model RiderDocument {
  id         String         @id @default(cuid())
  riderId    String
  rider      RiderProfile   @relation(fields: [riderId], references: [id])
  type       RiderDocType
  fileUrl    String
  status     DocumentStatus @default(PENDING)
  uploadedAt DateTime       @default(now())
  reviewedAt DateTime?
  expiresAt  DateTime? 
  reviewNote String?

  @@index([riderId, status])
}

//_________logs & transaction_________
model ShipmentLog {
  id          String         @id @default(cuid())
  shipmentId  String
  shipment    Shipment       @relation(fields: [shipmentId], references: [id])
  status      ShipmentStatus
  note        String?
  updatedById String
  updatedBy   User           @relation(fields: [updatedById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([shipmentId])
}

model Transaction {
  id               String      @id @default(cuid())
  shipmentId       String      @unique
  shipment         Shipment    @relation(fields: [shipmentId], references: [id])
  paymentType      PaymentType
  totalFare        Float
  codAmount        Float       @default(0)
  collectedByRider Float       @default(0)
  isRemitted       Boolean     @default(false)
  remittedAt       DateTime?
  createdAt        DateTime    @default(now())
}
